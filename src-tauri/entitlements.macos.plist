<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for kSecUseDataProtectionKeychain (DataProtection keychain avoids
         the login-keychain lock prompt). $(AppIdentifierPrefix) is resolved to the
         team ID at signing time; e.g. ABCDEF1234.org.subsurfacedivelog.prototype -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)org.subsurfacedivelog.prototype</string>
    </array>
    <key>com.apple.security.device.bluetooth</key>
    <true/>
</dict>
</plist>
